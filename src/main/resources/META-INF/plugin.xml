<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.mikrzo.cucumbergo</id>
    <name>Cucumber Go</name>
    <vendor>mik-rzo</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.go</depends>
    <depends>gherkin</depends>

    <extensions defaultExtensionNs="org.jetbrains.plugins.cucumber.steps">
        <cucumberJvmExtensionPoint implementation="com.github.mikrzo.cucumbergo.CucumberExtension"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">

        <completion.contributor
                language="Gherkin"
                order="first"
                implementationClass="com.github.mikrzo.cucumbergo.completion.StepCompletionContributor"/>

        <fileBasedIndex implementation="com.github.mikrzo.cucumbergo.CucumberGoStepIndex"/>

        <pom.declarationSearcher implementation="com.github.mikrzo.cucumbergo.search.StepDeclarationSearcher"/>
        <referencesSearch implementation="com.github.mikrzo.cucumbergo.search.StepDefinitionUsageSearcher"/>
        <findUsagesHandlerFactory
                implementation="com.github.mikrzo.cucumbergo.search.StepFindUsagesHandlerFactory"/>
        <usageTypeProvider
                implementation="com.github.mikrzo.cucumbergo.search.StepUsageTypeProvider"/>
        <codeInsight.lineMarkerProvider
                language="go"
                implementationClass="com.github.mikrzo.cucumbergo.search.CucumberLineMarkerProvider"/>
        <runConfigurationProducer
                implementation="com.github.mikrzo.cucumbergo.run.GodogRunConfigurationProducer"/>
    </extensions>


</idea-plugin>
